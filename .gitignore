# ============================================================================
# CompeteIQ — .gitignore
# Covers: Next.js, TypeScript, Prisma, Vercel, common IDEs, OS noise.
# Only .env.example is checked in. Everything secret stays local.
# ============================================================================

# ---- Dependencies ----------------------------------------------------------
node_modules/
.pnp
.pnp.js
.pnp.cjs
.yarn/install-state.gz
.yarn/cache
.yarn/build-state.yml

# ---- Build output ----------------------------------------------------------
.next/
/out/
/build/
/dist/

# ---- TypeScript ------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# ---- Environment variables (NEVER commit secrets) --------------------------
# Anything matching .env* is excluded EXCEPT .env.example (the template).
.env
.env.local
.env.development
.env.development.local
.env.production
.env.production.local
.env.test
.env.test.local
.env.*.local
!.env.example

# ---- Prisma ----------------------------------------------------------------
# The generated client is regenerated on every build (see package.json).
# prisma/migrations/ IS committed — those are the source of truth for the DB.
prisma/*.db
prisma/*.db-journal
prisma/.cache/

# ---- Vercel ----------------------------------------------------------------
.vercel/

# ---- Testing / coverage ----------------------------------------------------
/coverage/
*.lcov
.nyc_output/

# ---- Logs ------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---- IDE / Editor ----------------------------------------------------------
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
*.swp
*.swo
*~

# ---- OS noise --------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---- Misc ------------------------------------------------------------------
*.pem
*.key
*.crt
.husky/_/

# ---- Per-developer Claude Code config (not for the repo) ------------------
.claude/settings.local.json
