# =============================================================================
# REQUIRED — without these the app won't run
# =============================================================================

# Postgres. Free options: https://neon.tech, https://supabase.com,
# https://vercel.com/postgres.
#
# NEON USERS: paste the POOLED connection here (hostname contains "-pooler"),
# and append `?sslmode=require&pgbouncer=true&connect_timeout=10`.
# Pooled URL survives Neon's auto-suspend and works with serverless functions.
#
# Example:
#   postgresql://user:pwd@ep-abc-123-pooler.us-east-2.aws.neon.tech/db?sslmode=require&pgbouncer=true&connect_timeout=10
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler/DB?sslmode=require&pgbouncer=true&connect_timeout=10"

# DIRECT (non-pooled) connection. Used only by `prisma db push` / `migrate` —
# never by the running app. On Neon, copy the "Direct connection" URL.
#
# Example:
#   postgresql://user:pwd@ep-abc-123.us-east-2.aws.neon.tech/db?sslmode=require
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# 64+ random chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-me-with-a-long-random-string"

# Public origin of your app. Used for OAuth redirects, magic-link callbacks,
# certificate verify URLs, email links, etc. In dev: http://localhost:3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"


# =============================================================================
# FRONTEND TOGGLES
# =============================================================================

# Set to "true" to use the bundled mock fixtures instead of the real backend.
# Default is FALSE → real /api routes.
NEXT_PUBLIC_USE_MOCKS="false"

# Only set if backend is on a different origin than the frontend.
# NEXT_PUBLIC_API_URL="http://localhost:3000"


# =============================================================================
# EMAIL — Resend (free tier: 3000/month, 100/day)
# https://resend.com → API Keys
# =============================================================================
RESEND_API_KEY=""
# A verified sender domain on Resend. Until you verify a domain you can use
# their onboarding sandbox: "onboarding@resend.dev".
EMAIL_FROM="CompeteIQ <onboarding@resend.dev>"


# =============================================================================
# STRIPE — payments
# https://dashboard.stripe.com/test/apikeys
# =============================================================================
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# From `stripe listen --forward-to localhost:3000/api/billing/webhook`
STRIPE_WEBHOOK_SECRET=""

# Price IDs for each plan (create them in your Stripe dashboard, then paste here).
# Until set, the corresponding plan's Checkout button is disabled.
STRIPE_PRICE_STARTER_MONTHLY=""
STRIPE_PRICE_STARTER_ANNUAL=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_ANNUAL=""


# =============================================================================
# GOOGLE OAUTH — "Sign in with Google"
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
# =============================================================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""


# =============================================================================
# UPSTASH REDIS — rate limiting (free tier: 10k commands/day)
# https://upstash.com → Redis → Create Database → REST URL + Token
# When unset, falls back to an in-memory rate limiter (single-instance only).
# =============================================================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""


# =============================================================================
# CLOUDFLARE R2 — file storage (free up to 10GB egress/month)
# Endpoint format: https://<accountId>.r2.cloudflarestorage.com
# =============================================================================
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
# Public URL prefix for served files (custom domain or r2.dev subdomain).
R2_PUBLIC_URL=""


# =============================================================================
# AI QUESTION GENERATION
# Set ONE of GROQ_API_KEY or OPENAI_API_KEY (Groq is checked first).
# Without either, the generator falls back to templated questions.
# =============================================================================

# Groq — free tier with generous rate limits. Recommended for dev + low-cost prod.
# https://console.groq.com → API Keys
GROQ_API_KEY=""
# Available models (Dec 2024):
#   llama-3.3-70b-versatile  (default — strongest reasoning)
#   llama-3.1-8b-instant     (fastest)
#   mixtral-8x7b-32768       (long context)
GROQ_MODEL="llama-3.3-70b-versatile"

# OpenAI — used only if GROQ_API_KEY is empty.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
